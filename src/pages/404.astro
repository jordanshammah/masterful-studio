---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="404 — Page Not Found | Masterful"
  description="This page doesn't exist."
  path="/404/"
  showMasthead={false}
  navCta="audit"
>
  <meta name="robots" content="noindex" slot="schema" />

  <main>
    <section class="wrap" style="padding: 80px 0 120px; min-height: 60vh; display: flex; flex-direction: column; justify-content: center;">
      <div data-reveal>
        <p class="t-mono" style="font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mute); margin-bottom: 24px">
          Correction Notice · Vol. XII
        </p>
        <div style="border-top: 3px solid var(--ink); border-bottom: 1px solid var(--rule); padding: 32px 0; margin-bottom: 32px;">
          <div style="font-family: var(--display); font-size: clamp(80px, 14vw, 160px); line-height: 1; letter-spacing: -0.04em; color: var(--ink);">
            404
          </div>
          <h1 style="font-family: var(--serif); font-size: clamp(24px, 3.5vw, 40px); line-height: 1.2; letter-spacing: -0.01em; margin-top: 16px; margin-bottom: 0;">
            This page went to press.<br><em>It never shipped.</em>
          </h1>
        </div>
        <p style="font-size: 15px; line-height: 1.6; color: var(--mute); max-width: 480px; margin-bottom: 32px;">
          The URL you followed doesn't exist — it may have moved, been retired, or never existed. The masthead stands, though.
        </p>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <a href="/" class="btn btn-orange">Back to the masthead →</a>
          <a href="/journal/" class="btn btn-ghost">Read the journal</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
