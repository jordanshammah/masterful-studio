---
import BaseLayout from '../layouts/BaseLayout.astro';

const SITE = 'https://masterful-app.com';
const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfessionalService',
      '@id': `${SITE}/#organization`,
      name: 'Masterful',
      description:
        'A search visibility studio that builds brand presence across SEO, AEO, and GEO: Google, AI answer engines, and the entity data models read when forming recommendations.',
      url: SITE,
      email: 'jordanshammah@masterful-app.com',
      founder: { '@type': 'Person', '@id': `${SITE}/#jordan-shammah`, name: 'Jordan Shammah' },
      areaServed: ['United States', 'United Kingdom', 'Kenya'],
      serviceType: ['SEO', 'Answer Engine Optimization', 'Generative Engine Optimization'],
      knowsAbout: [
        'Answer Engine Optimization',
        'Generative Engine Optimization',
        'Search Engine Optimization',
        'AI Citation Optimization',
        'LLM Citation Building',
        'Search Visibility',
        'Perplexity Optimization',
        'ChatGPT Optimization',
        'Topical Authority',
      ],
      logo: { '@type': 'ImageObject', url: `${SITE}/assets/og-image.png` },
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE}/#website`,
      url: SITE,
      name: 'Masterful — A Search Visibility Studio',
      alternateName: 'Masterful',
      publisher: { '@id': `${SITE}/#organization` },
    },
  ],
};
---
<BaseLayout
  title="Masterful | A Search Visibility Studio"
  description="SEO, AEO, and GEO. Three months minimum. Flat rate. Organic only."
  path="/"
  showMasthead={false}
>
  <script type="application/ld+json" slot="schema" set:html={JSON.stringify(graph)} />

  <!-- NEWSPAPER MASTHEAD -->
  <header class="home-masthead">
    <div class="home-masthead-inner">
      <div class="hm-top">
        <div class="hm-title" data-hero="1">The Masterful</div>
        <span class="hm-quote" data-hero="2">"Become<br>the answer"</span>
      </div>
      <div class="hm-bottom" data-hero="3">
        <span class="hm-vol">Vol. XII · No. 04</span>
        <span class="hm-vol">The Visibility Issue · May 2026</span>
        <span class="hm-vol">Free · Always</span>
      </div>
    </div>
  </header>

  <main>
  <section class="wrap">
    <div class="lead-story" data-reveal>
      <div class="lead-l">
        <h1 class="lead-headline">AI ate Google.</h1>
        <p class="lead-subhead">You end up as the answer or a footnote.</p>
        <p class="lead-byline">By a search visibility studio</p>
        <p class="lead-body">Masterful runs SEO, AEO, and GEO. Three months minimum. Flat rate. Organic only.</p>
        <div class="lead-ctas">
          <a href="/audit/" class="btn btn-orange">Run a free audit</a>
          <a href="/work/" class="btn btn-ghost">See our work</a>
        </div>
        <p style="margin-top:20px"><a href="/journal/google-replaced-the-search-bar/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--orange)">Read the entry →</a></p>
      </div>
      <div class="lead-r">
        <!-- Classifieds sidebar -->
        <div class="classifieds-kicker" style="margin-bottom:16px">Classifieds · Services</div>
        <div style="display:flex;flex-direction:column;gap:0;border:1px solid var(--rule)">
          <div style="padding:18px;border-bottom:1px solid var(--rule)">
            <div class="classified-label">Wanted</div>
            <div class="classified-service">AEO</div>
            <p class="classified-desc" style="font-size:13px;line-height:1.5">We build pages that ChatGPT, Perplexity, and Claude cite by name.</p>
          </div>
          <div style="padding:18px;border-bottom:1px solid var(--rule)">
            <div class="classified-label">Help Offered</div>
            <div class="classified-service">SEO</div>
            <p class="classified-desc" style="font-size:13px;line-height:1.5">Content strategy and technical fixes built to earn Google rankings.</p>
          </div>
          <div style="padding:18px">
            <div class="classified-label">Notice</div>
            <div class="classified-service">GEO</div>
            <p class="classified-desc" style="font-size:13px;line-height:1.5">We put your brand on Wikipedia and the reference sources AI tools consult before citing anyone.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule">

  <!-- SAMPLE AUDIT REPORT -->
  <section class="audit-sample">
    <div class="wrap">
      <div class="kicker" style="margin-bottom:32px">A Peek at the Report: What You'll Get Back <span class="kicker-num">/ XII</span></div>
      <div class="audit-header" data-reveal>
        <div class="audit-intro">
          <h2>An 18-page <em>visibility</em> autopsy</h2>
          <p>Fill in the form. A human sends back a PDF and a short Loom video within 48 hours.</p>
          <ul class="audit-checklist">
            <li>How often 6 major AI tools mention your brand by name</li>
            <li>Top 50 questions your buyers ask AI tools</li>
            <li>How AI tools understand your business and what's stopping them from recommending you</li>
            <li>Competitor citation map</li>
            <li>90-day plan, prioritised</li>
          </ul>
          <br>
          <a href="/audit/" class="btn btn-orange" style="margin-top:8px">Request the report</a>
        </div>
        <div class="audit-report glass">
          <div class="ar-header">
            <span>Sample · Redacted Client · Pg. 04</span>
            <span>masterful / audit 2026.05</span>
          </div>
          <div style="font-size:9px;letter-spacing:0.08em;text-transform:uppercase;color:var(--mute-light);margin-bottom:12px">Visibility Score</div>
          <div class="ar-score-section">
            <div>
              <span class="ar-score-n">27</span><span class="ar-score-denom">/100</span>
            </div>
            <p class="ar-score-verdict">"Exists on Google. Invisible to answer engines."</p>
          </div>
          <div class="ar-findings">Findings · cited in 10 high-intent prompts</div>
          <div class="ar-model-row">
            <span class="ar-model-name">ChatGPT 4o</span><span class="ar-model-badge">3 citations</span>
          </div>
          <div class="ar-model-row">
            <span class="ar-model-name">Perplexity</span><span class="ar-model-badge">2 citations</span>
          </div>
          <div class="ar-model-row">
            <span class="ar-model-name">Claude 3.5</span><span class="ar-model-badge">2 citations</span>
          </div>
          <div class="ar-model-row">
            <span class="ar-model-name">Gemini 1.5</span><span class="ar-model-badge">1 citation</span>
          </div>
          <div class="ar-model-row">
            <span class="ar-model-name">Llama 3.1</span><span class="ar-model-badge">1 citation</span>
          </div>
          <div class="ar-model-row" style="border:0">
            <span class="ar-model-name">Grok 2</span><span class="ar-model-badge">1 citation</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule">

  <!-- ANIMATED BRAND / CTA BRIDGE -->
  <section style="background:var(--ink);padding:0">
    <div class="wrap brand-bridge" style="max-width:1200px;display:grid;grid-template-columns:1fr 1fr;gap:0;border-top:1px solid var(--rule-light)">
      <div class="brand-bridge-text" style="padding:64px 48px 64px 0;border-right:1px solid var(--rule-light)">
        <p style="font-family:var(--serif);font-size:clamp(22px,2.8vw,32px);line-height:1.35;letter-spacing:-0.01em;color:var(--cream);margin-bottom:0">A search visibility studio. Flat monthly rate. All organic.</p>
      </div>
      <div class="brand-bridge-video" style="overflow:hidden;max-height:260px;display:flex;align-items:center;justify-content:center;background:var(--ink)">
        <video autoplay loop muted playsinline style="width:260px;height:260px;object-fit:cover;opacity:0.9" aria-hidden="true">
          <source src="/assets/masterful-pfp.webm" type="video/webm">
        </video>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section on-dark" style="padding:80px 32px;border-top:1px solid var(--rule-light)">
    <div class="wrap" style="max-width:700px">
      <p class="t-mono" style="font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:var(--mute-light);margin-bottom:24px">Back Cover · Take Action</p>
      <h2 style="font-family:var(--serif);font-size:clamp(40px,5vw,68px);line-height:1.0;letter-spacing:-0.02em;margin-bottom:12px">Get on the <em style="font-style:italic">shortlist</em></h2>
      <p class="t-mono" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute-light);margin-bottom:32px">Start the 6-question audit · Free · Human reply within 48 hours</p>
      <a href="/audit/" class="btn btn-orange">Start the audit →</a>
    </div>
  </section>
  </main>
</BaseLayout>
