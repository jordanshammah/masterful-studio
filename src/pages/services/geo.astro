---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
const SITE = 'https://masterful-app.com';
const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: 'Generative Engine Optimization',
      alternateName: 'GEO',
      description:
        'Generative engine optimization is the practice of building a brand\'s presence on the external sources that AI models read when forming knowledge: Wikipedia, Wikidata, Reddit, authoritative directories, and editorial publications. Where AEO targets what a model retrieves in a single query, GEO targets what the model already knows about a brand before any query is asked.',
      provider: { '@type': 'ProfessionalService', '@id': `${SITE}/#organization`, name: 'Masterful', url: SITE },
      serviceType: 'Generative Engine Optimization',
      url: `${SITE}/services/geo/`,
      areaServed: ['United States', 'United Kingdom', 'Kenya'],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        { '@type': 'Question', name: 'What is generative engine optimization?', acceptedAnswer: { '@type': 'Answer', text: 'Generative engine optimization (GEO) is the practice of building a brand\'s presence on the sources AI models trust most: Wikipedia, Wikidata, Reddit, and authoritative editorial publications. AI tools pull brand descriptions, categories, and facts from these sources when forming recommendations. GEO makes sure those sources exist, are accurate, and say consistent things about your brand.' } },
        { '@type': 'Question', name: 'How long does GEO take?', acceptedAnswer: { '@type': 'Answer', text: 'GEO compounds over 12 to 24 months. It is the slowest of the three search disciplines and the hardest for a competitor to reverse-engineer once it is in place. Brands that start GEO earlier hold their category position longer because model training data updates infrequently and rewards established entity signals.' } },
        { '@type': 'Question', name: 'What is the difference between GEO and AEO?', acceptedAnswer: { '@type': 'Answer', text: 'AEO targets what an AI tool retrieves when a user asks a specific question. GEO targets what the model already knows about your brand before any query is asked. GEO works at the training data and entity recognition layer: Wikipedia entries, Wikidata profiles, Reddit presence, and citation sources that models read during training. AEO works at the retrieval layer during inference.' } },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Services', item: `${SITE}/services/` },
        { '@type': 'ListItem', position: 2, name: 'GEO', item: `${SITE}/services/geo/` },
      ],
    },
  ],
};
---
<BaseLayout
  title="GEO: Generative Engine Optimization | Masterful"
  description="Generative engine optimization. Wikipedia, Wikidata, Reddit, and the knowledge graphs that AI models read."
  path="/services/geo/"
  navActive="services"
>
  <script type="application/ld+json" slot="schema" set:html={JSON.stringify(graph)} />
  <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Services', href: '/services/' }, { name: 'GEO' }]} />

  <main>
  <section class="service-hero wrap">
    <div class="kicker" style="margin-bottom:20px">Service No. III · Generative Engine Optimization</div>
    <div class="sh-meta">
      <span class="sh-meta-item">Minimum 3 months</span>
      <span class="sh-meta-item">Flat retainer</span>
    </div>
    <h1 class="sh-headline">GEO:<br>the long <em>game.</em></h1>
    <p class="lead-body" style="max-width:640px;margin-bottom:32px">
      Generative engine optimization (GEO) is the practice of building a brand's presence on the external sources that AI models read when forming knowledge: Wikipedia, Wikidata, Reddit, and authoritative editorial publications. Where AEO targets what a model retrieves in a single query, GEO targets what the model already knows about a brand before any query is asked. It is the slowest of the three search disciplines and the hardest to reverse once established.
    </p>
    <p class="sh-tagline">AI tools learn from the web. They trust Wikipedia, Wikidata, Reddit, and authoritative editorial sources far more than most brand websites.</p>
    <a href="/audit/" class="btn btn-orange">Run a free audit</a>
  </section>

  <section class="pillars wrap">
    <div class="kicker" style="margin-bottom:32px">What We Build <span class="kicker-num">/ XII</span></div>
    <div class="pillar-grid">
      <div class="pillar">
        <h3>Making sure AI tools know who you are</h3>
        <p>We correct or create your brand's profile on Wikipedia and Wikidata, the sources AI tools trust most when deciding how to describe a business. Your category, description, and key facts need to match across every source they read. Inconsistencies produce wrong citations or no citations.</p>
      </div>
      <div class="pillar">
        <h3>Reddit presence</h3>
        <p>Honest presence in the communities models read. Participation, not spam. The subreddits relevant to your category are a significant source of what models learn about brands like yours.</p>
      </div>
      <div class="pillar">
        <h3>Consistent facts across every source AI reads</h3>
        <p>AI tools pull your brand's name, description, and category from dozens of sources. When those sources say different things, AI tools get confused or cite you incorrectly. We make them consistent: Wikipedia, Wikidata, Crunchbase, LinkedIn, industry directories, and editorial publications.</p>
      </div>
      <div class="pillar">
        <h3>Citation source building</h3>
        <p>Placements in publications and reference sources that carry weight in model training data. Industry directories, editorial features, authoritative regional and sector press.</p>
      </div>
    </div>
  </section>

  <section class="wrap" style="padding:48px 0;border-bottom:1px solid var(--rule)">
    <div class="kicker" style="margin-bottom:20px">A Note on Timeline</div>
    <p style="font-size:15px;line-height:1.72;color:var(--ink);max-width:660px">GEO compounds over 12 to 24 months. It is the slowest of the three disciplines and the hardest for a competitor to reverse-engineer once it is in place. The brands that start earlier hold the category longer.</p>
  </section>

  <section class="wrap section-sm" style="display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--rule)">
    <a href="/services/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute)">← All services</a>
    <div class="silo-links">
      <a href="/services/seo/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute)">← SEO</a>
      <a href="/services/aeo/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute)">← AEO</a>
    </div>
  </section>

  <section class="on-dark" style="padding:80px 32px;text-align:center">
    <div class="wrap" style="max-width:600px">
      <p style="font-size:15px;line-height:1.65;color:rgba(244,240,232,0.65);max-width:440px;margin:0 auto 24px">The free audit includes your current entity recognition status and which reference sources are missing.</p>
      <a href="/audit/" class="btn btn-orange">Run a free audit</a>
    </div>
  </section>
  </main>
</BaseLayout>
