---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
const SITE = 'https://masterful-app.com';
const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${SITE}/#organization`,
  name: 'Masterful',
  description: 'A search visibility studio offering SEO, AEO, and GEO services.',
  url: SITE,
  email: 'jordanshammah@masterful-app.com',
  founder: { '@type': 'Person', '@id': `${SITE}/#jordan-shammah`, name: 'Jordan Shammah' },
  areaServed: ['United States', 'United Kingdom', 'Kenya'],
  serviceType: ['SEO', 'Answer Engine Optimization', 'Generative Engine Optimization'],
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE}/services/` },
  ],
};
---
<BaseLayout
  title="Search Visibility Services: SEO, AEO & GEO | Masterful"
  description="Masterful runs SEO, AEO and GEO so you become the answer AI tools cite, not a footnote. Flat rate, organic only, three-month minimum."
  path="/services/"
  navActive="services"
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(serviceLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  </Fragment>

  <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Services' }]} />

  <main>
  <section class="section wrap">
    <div class="kicker" style="margin-bottom:32px">Services Index</div>

    <div style="padding-bottom:48px;border-bottom:1px solid var(--rule)">
      <h1 style="font-family:var(--serif);font-size:clamp(40px,5vw,64px);line-height:1.0;letter-spacing:-0.02em;margin-bottom:8px">Search visibility services</h1>
      <p style="font-size:15px;line-height:1.65;color:var(--mute);max-width:540px">SEO, AEO, and GEO. One engagement. One retainer. Each discipline is a surface where your buyers are looking. We cover all three.</p>
    </div>

    <div style="display:flex;gap:0;padding:32px 0;border-bottom:1px solid var(--rule)">
      <div style="padding-right:48px;border-right:1px solid var(--rule);margin-right:48px">
        <div style="font-family:var(--serif);font-size:56px;line-height:1;letter-spacing:-0.03em">3</div>
        <div style="font-family:var(--mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute)">Disciplines</div>
      </div>
      <div>
        <div style="font-family:var(--serif);font-size:56px;line-height:1;letter-spacing:-0.03em">3mo</div>
        <div style="font-family:var(--mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute)">Minimum contract</div>
      </div>
    </div>

    <!-- SEO -->
    <div class="service-card" data-reveal>
      <div class="sc-l">
        <div class="sc-num">§ SEO · Search Engine Optimization / XII</div>
        <h2 class="sc-name">SEO</h2>
        <div class="sc-label">Search Engine Optimization</div>
        <a href="/services/seo/" class="btn" style="margin-top:12px">Read the method →</a>
      </div>
      <div class="sc-r">
        <p class="sc-tagline">The boring engine</p>
        <p class="sc-body">Google handles 4.8 billion searches a day. We treat it like infrastructure: technical foundations, topical authority, and editorial content at the right pace.</p>
        <a href="/services/seo/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--orange)">Full breakdown →</a>
      </div>
    </div>

    <!-- AEO -->
    <div class="service-card" data-reveal>
      <div class="sc-l">
        <div class="sc-num">II · AEO · Answer Engine Optimization / XII</div>
        <h2 class="sc-name">AEO</h2>
        <div class="sc-label">Answer Engine Optimization</div>
        <p style="font-size:13px;line-height:1.5;color:var(--mute);margin-top:6px">Getting AI tools like ChatGPT and Perplexity to recommend your brand by name.</p>
        <a href="/services/aeo/" class="btn" style="margin-top:12px">Read the method →</a>
      </div>
      <div class="sc-r">
        <p class="sc-tagline">Built to be cited</p>
        <p class="sc-body">ChatGPT and Perplexity recommend brands by name. We build the pages that earn those citations.</p>
        <a href="/services/aeo/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--orange)">Full breakdown →</a>
      </div>
    </div>

    <!-- GEO -->
    <div class="service-card" data-reveal>
      <div class="sc-l">
        <div class="sc-num">III · GEO · Generative Engine Optimization / XII</div>
        <h2 class="sc-name">GEO</h2>
        <div class="sc-label">Generative Engine Optimization</div>
        <p style="font-size:13px;line-height:1.5;color:var(--mute);margin-top:6px">Building your brand's presence on the sources AI tools read when deciding what to recommend.</p>
        <a href="/services/geo/" class="btn" style="margin-top:12px">Read the method →</a>
      </div>
      <div class="sc-r">
        <p class="sc-tagline">The reference layer</p>
        <p class="sc-body">We put your brand on Wikipedia, Wikidata, Reddit, and the other sources models read when deciding what to recommend. This work compounds over years.</p>
        <a href="/services/geo/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--orange)">Full breakdown →</a>
      </div>
    </div>

    <!-- Premium tier: web design -->
    <div style="display:grid;grid-template-columns:1fr 2fr;gap:0;border-bottom:1px solid var(--rule);padding:48px 0" class="service-card" data-reveal>
      <div class="sc-l">
        <div class="sc-num">+ Premium tier · Web Design / XII</div>
        <h2 class="sc-name" style="font-size:clamp(28px,3vw,44px)">Web design</h2>
        <div class="sc-label">Built for search visibility</div>
        <a href="/services/web-design/" class="btn" style="margin-top:12px">See the premium tier →</a>
      </div>
      <div class="sc-r">
        <p class="sc-tagline">When the site is the constraint</p>
        <p class="sc-body">Premium websites engineered from the first line for SEO, AEO and GEO: fast, crawlable, and built to convert. For businesses where the current site, not just the content on it, is what's holding visibility back.</p>
        <a href="/services/web-design/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--orange)">Full breakdown →</a>
      </div>
    </div>

    <!-- Engagement options -->
    <div style="padding:48px 0;border-top:1px solid var(--rule)">
      <div class="kicker" style="margin-bottom:32px">The Engagement <span class="kicker-num">/ XII</span></div>
      <h2 style="font-family:var(--serif);font-size:clamp(32px,4vw,52px);line-height:1.0;letter-spacing:-0.02em;margin-bottom:40px">Four ways in.</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--rule)">
        <div style="padding:32px;border-right:1px solid var(--rule);border-bottom:1px solid var(--rule)">
          <div style="font-family:var(--mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute);margin-bottom:14px">Free · 48 hours</div>
          <h3 style="font-family:var(--sans);font-size:17px;font-weight:600;margin-bottom:10px">Free preliminary scan</h3>
          <p style="font-size:14px;line-height:1.65;color:var(--mute);margin-bottom:24px">We run your brand across ChatGPT, Perplexity, and Google AI Overviews. You get a PDF with your visibility score, where competitors are outranking you in AI answers, and three actions ranked by impact. One reply from a human. No pitch attached.</p>
          <a href="/audit/" class="btn btn-orange">Request the free scan →</a>
        </div>
        <div style="padding:32px;border-bottom:1px solid var(--rule);background:rgba(196,80,26,0.04)">
          <div style="font-family:var(--mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:var(--orange);margin-bottom:14px">$397 · 5 working days</div>
          <h3 style="font-family:var(--sans);font-size:17px;font-weight:600;margin-bottom:10px">Full audit</h3>
          <p style="font-size:14px;line-height:1.65;color:var(--mute);margin-bottom:24px">The deep version. How often 6 major AI tools mention your brand by name, the top 50 questions your buyers ask mapped per platform, a full competitor citation map, technical foundation audit, and a 90-day roadmap ranked by effort and impact. 18 pages. Includes a Loom walkthrough.</p>
          <a href="/audit/?type=full" class="btn btn-orange">Request the full audit →</a>
        </div>
        <div style="padding:32px;border-right:1px solid var(--rule)">
          <div style="font-family:var(--mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute);margin-bottom:14px">Monthly · Three-month minimum</div>
          <h3 style="font-family:var(--sans);font-size:17px;font-weight:600;margin-bottom:10px">Core retainer</h3>
          <p style="font-size:14px;line-height:1.65;color:var(--mute);margin-bottom:24px">Masterful executes the fix. Technical foundations in week one. Content published monthly. Citation source building from month two. Monthly visibility report showing movement across every AI tool we track. Two tiers available. Scope confirmed after the audit.</p>
          <a href="/audit/" class="btn">Start with the free scan →</a>
        </div>
        <div style="padding:32px">
          <div style="font-family:var(--mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute);margin-bottom:14px">One-time + Monthly · Six-month minimum</div>
          <h3 style="font-family:var(--sans);font-size:17px;font-weight:600;margin-bottom:10px">Premium bundle</h3>
          <p style="font-size:14px;line-height:1.65;color:var(--mute);margin-bottom:24px">A full website rebuild structured for AI visibility from the ground up, combined with a six-month retainer. For businesses where the current site is the constraint, not just the content on it.</p>
          <a href="/audit/" class="btn">Start with the free scan →</a>
        </div>
      </div>
    </div>

    <!-- Not for hire -->
    <div style="padding:48px 0 0">
      <div class="kicker">A Note on What We Don't Do</div>
      <p style="font-family:var(--mono);font-size:12px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute);margin-bottom:24px">Not for hire</p>
      <div class="not-for-hire">
        <div class="nfh-item">
          <h4>Paid</h4>
          <p>We have studio contacts we trust for ads. Ask, and we'll make an introduction.</p>
        </div>
        <div class="nfh-item">
          <h4>CRO</h4>
          <p>We focus on the search and discovery stages.</p>
        </div>
        <div class="nfh-item">
          <h4>Brand identity</h4>
          <p>We edit brand voice well. Wordmarks go to a designer.</p>
        </div>
        <div class="nfh-item">
          <h4>Lock-in</h4>
          <p>Three-month minimums. Month-to-month after that.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="on-dark" style="padding:80px 32px;text-align:center">
    <div class="wrap" style="max-width:600px">
      <p class="t-mono" style="font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:var(--mute-light);margin-bottom:20px">Back Cover · Take Action</p>
      <h2 style="font-family:var(--serif);font-size:clamp(36px,5vw,60px);line-height:1.0;letter-spacing:-0.02em;margin-bottom:28px">Get on the <em style="font-style:italic">shortlist</em></h2>
      <a href="/audit/" class="btn btn-orange">Start the 6-question audit →</a>
      <p style="font-family:var(--mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute-light);margin-top:16px">Free · Human reply within 48 hours</p>
    </div>
  </section>
  </main>
</BaseLayout>
