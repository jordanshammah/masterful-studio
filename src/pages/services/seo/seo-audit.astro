---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
const SITE = 'https://masterful-app.com';
const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: 'SEO Audit',
      description:
        'A full technical and content audit with a prioritised 90-day fix list, not a 200-page PDF nobody reads.',
      provider: { '@type': 'ProfessionalService', '@id': `${SITE}/#organization`, name: 'Masterful', url: SITE },
      serviceType: 'SEO Audit',
      url: `${SITE}/services/seo/seo-audit/`,
      areaServed: ['Kenya', 'Nigeria', 'South Africa', 'Egypt', 'United Arab Emirates', 'United Kingdom', 'United States'],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Services', item: `${SITE}/services/` },
        { '@type': 'ListItem', position: 2, name: 'SXO & Core SEO', item: `${SITE}/services/seo/` },
        { '@type': 'ListItem', position: 3, name: 'SEO Audit', item: `${SITE}/services/seo/seo-audit/` },
      ],
    },
  ],
};
---
<BaseLayout
  title="SEO Audit Services | Masterful"
  description="A full technical and content SEO audit that ends in a prioritised 90-day fix list, not a 200-page PDF nobody ever reads or acts on."
  path="/services/seo/seo-audit/"
  navActive="services"
>
  <script type="application/ld+json" slot="schema" set:html={JSON.stringify(graph)} />
  <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Services', href: '/services/' }, { name: 'SXO & Core SEO', href: '/services/seo/' }, { name: 'SEO audit' }]} />

  <main>
  <section class="service-hero wrap">
    <div class="kicker" style="margin-bottom:20px">SXO & Core SEO · SEO Audit</div>
    <div class="sh-meta">
      <span class="sh-meta-item">Diagnosis first</span>
      <span class="sh-meta-item">90-day fix list</span>
    </div>
    <h1 class="sh-headline">SEO audit</h1>
    <p class="lead-body" style="max-width:640px;margin-bottom:32px">
      An SEO audit is a full technical and content review that ends in a prioritised plan, not a data dump. We look at how Google and AI crawlers read your site, where the content gaps are against the questions your buyers ask, and what is quietly suppressing your rankings. Then we hand you a 90-day fix list ranked by effort and impact, so the first thing you do is the thing that moves the needle.
    </p>
    <p class="sh-tagline">A 200-page PDF nobody reads is not an audit. A prioritised fix list you can act on this quarter is.</p>
    <a href="/audit/" class="btn btn-orange">Start with the free audit</a>
  </section>

  <section class="pillars wrap">
    <div class="kicker" style="margin-bottom:32px">What's Covered <span class="kicker-num">/ XII</span></div>
    <div class="pillar-grid">
      <div class="pillar">
        <h3>Technical health</h3>
        <p>Crawlability, indexing, Core Web Vitals, schema, and redirect hygiene, scored against current Google guidance.</p>
      </div>
      <div class="pillar">
        <h3>Content and topical gaps</h3>
        <p>Where your coverage is thin against the queries and prompts your buyers actually use, and which clusters to build first.</p>
      </div>
      <div class="pillar">
        <h3>Competitor benchmark</h3>
        <p>Who is ranking and getting cited in your category, and the specific structures that are earning them the position.</p>
      </div>
      <div class="pillar">
        <h3>Prioritised 90-day plan</h3>
        <p>Every finding ranked by effort and impact, so the sequence is obvious and the first month's work is the highest-leverage work.</p>
      </div>
    </div>
  </section>

  <section class="wrap section-sm" style="display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--rule)">
    <a href="/services/seo/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute)">← SXO & Core SEO</a>
    <div class="silo-links">
      <a href="/services/seo/technical-seo/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute)">← Technical SEO</a>
      <a href="/audit/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--orange)">Free audit →</a>
    </div>
  </section>

  <section class="on-dark" style="padding:80px 32px;text-align:center">
    <div class="wrap" style="max-width:600px">
      <p style="font-size:15px;line-height:1.65;color:rgba(244,240,232,0.65);max-width:440px;margin:0 auto 24px">The free scan is the front door to the full audit. Six questions, an 18-page report, a human reply within 48 hours.</p>
      <a href="/audit/" class="btn btn-orange">Run a free audit</a>
    </div>
  </section>
  </main>
</BaseLayout>
