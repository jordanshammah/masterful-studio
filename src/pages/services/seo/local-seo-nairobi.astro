---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
const SITE = 'https://masterful-app.com';
const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: 'Local SEO Nairobi',
      description:
        'Get found by customers searching in Nairobi: Google Business Profile, local citations, and reviews that rank you in the map pack.',
      provider: { '@type': 'ProfessionalService', '@id': `${SITE}/#organization`, name: 'Masterful', url: SITE },
      serviceType: 'Local SEO',
      url: `${SITE}/services/seo/local-seo-nairobi/`,
      areaServed: { '@type': 'City', name: 'Nairobi', containedInPlace: { '@type': 'Country', name: 'Kenya' } },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Services', item: `${SITE}/services/` },
        { '@type': 'ListItem', position: 2, name: 'SEO', item: `${SITE}/services/seo/` },
        { '@type': 'ListItem', position: 3, name: 'Local SEO Nairobi', item: `${SITE}/services/seo/local-seo-nairobi/` },
      ],
    },
  ],
};
---
<BaseLayout
  title="Local SEO Nairobi | Masterful"
  description="Get found by customers searching in Nairobi: Google Business Profile, local citations, and reviews that rank you in the map pack."
  path="/services/seo/local-seo-nairobi/"
  navActive="services"
>
  <script type="application/ld+json" slot="schema" set:html={JSON.stringify(graph)} />
  <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Services', href: '/services/' }, { name: 'SEO', href: '/services/seo/' }, { name: 'Local SEO Nairobi' }]} />

  <main>
  <section class="service-hero wrap">
    <div class="kicker" style="margin-bottom:20px">SEO · Local SEO Nairobi</div>
    <div class="sh-meta">
      <span class="sh-meta-item">Nairobi &amp; Kenya</span>
      <span class="sh-meta-item">Map pack focus</span>
    </div>
    <h1 class="sh-headline">Local SEO for<br>Nairobi <em>businesses.</em></h1>
    <p class="lead-body" style="max-width:640px;margin-bottom:32px">
      Local SEO is the work that puts you in front of customers searching from Nairobi: the map pack, Google Business Profile, and the local results that decide who gets the call. We get your profile complete and accurate, build the local citations that confirm who and where you are, and earn the reviews that move you up the pack. The same consistency work also feeds how AI tools describe local businesses when someone asks them for a recommendation.
    </p>
    <p class="sh-tagline">When someone in Nairobi searches for what you do, you are either in the map pack or you are not in the decision.</p>
    <a href="/audit/" class="btn btn-orange">Run a free audit</a>
  </section>

  <section class="pillars wrap">
    <div class="kicker" style="margin-bottom:32px">What We Build <span class="kicker-num">/ XII</span></div>
    <div class="pillar-grid">
      <div class="pillar">
        <h3>Google Business Profile</h3>
        <p>A complete, correctly categorised profile with accurate hours, services, and photos, optimised for the searches your Nairobi customers actually run.</p>
      </div>
      <div class="pillar">
        <h3>Local citations</h3>
        <p>Consistent name, address, and phone across the directories and local sources that confirm your business is real and where it says it is.</p>
      </div>
      <div class="pillar">
        <h3>Reviews that rank</h3>
        <p>A simple, honest review process that earns the volume and recency the map pack rewards, without anything that risks a penalty.</p>
      </div>
      <div class="pillar">
        <h3>Local content and entity consistency</h3>
        <p>Location-relevant pages and matching facts across every source, so both Google and AI tools describe your business the same way.</p>
      </div>
    </div>
  </section>

  <section class="wrap section-sm" style="display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--rule)">
    <a href="/services/seo/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute)">← SEO</a>
    <div class="silo-links">
      <a href="/sectors/nairobi-businesses/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--orange)">Nairobi businesses →</a>
      <a href="/audit/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute)">Free audit →</a>
    </div>
  </section>

  <section class="on-dark" style="padding:80px 32px;text-align:center">
    <div class="wrap" style="max-width:600px">
      <p style="font-size:15px;line-height:1.65;color:rgba(244,240,232,0.65);max-width:440px;margin:0 auto 24px">The free audit shows where you currently sit in local results and what is keeping you out of the map pack.</p>
      <a href="/audit/" class="btn btn-orange">Run a free audit</a>
    </div>
  </section>
  </main>
</BaseLayout>
