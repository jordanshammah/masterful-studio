---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
const SITE = 'https://masterful-app.com';
const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: 'Answer Engine Optimization',
      alternateName: 'AEO',
      description:
        "Answer engine optimization is the practice of structuring web content so that AI tools (ChatGPT, Perplexity, Claude, and Gemini) retrieve and cite it when answering user queries. Where SEO targets Google's ranking algorithm, AEO targets the retrieval and citation logic of large language models.",
      provider: { '@type': 'ProfessionalService', '@id': `${SITE}/#organization`, name: 'Masterful', url: SITE },
      serviceType: 'Answer Engine Optimization',
      url: `${SITE}/services/aeo/`,
      areaServed: ['United States', 'United Kingdom', 'Kenya'],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        { '@type': 'Question', name: 'What is answer engine optimization?', acceptedAnswer: { '@type': 'Answer', text: 'Answer engine optimization (AEO) is the practice of structuring web content so that AI tools like ChatGPT, Perplexity, Claude, and Gemini retrieve and cite it when answering user queries. A page optimized for AEO answers a specific question with a clear, liftable thesis, structured headers that match query language, and schema markup that signals what the content covers.' } },
        { '@type': 'Question', name: 'How long does AEO take to show results?', acceptedAnswer: { '@type': 'Answer', text: 'AEO results show up in 30 to 90 days on Perplexity. ChatGPT and Gemini take longer because their indexes update on different schedules. Masterful tracks results across 6 major AI tools weekly so the picture stays accurate, not selectively optimistic.' } },
        { '@type': 'Question', name: 'What is the difference between AEO and SEO?', acceptedAnswer: { '@type': 'Answer', text: "SEO optimizes content for Google's ranking algorithm. AEO optimizes content for the retrieval and citation logic of large language models. The structure, depth, and source signals that make a page citable by AI tools are different from what makes a page rank on Google. An integrated visibility strategy addresses both." } },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Services', item: `${SITE}/services/` },
        { '@type': 'ListItem', position: 2, name: 'AEO', item: `${SITE}/services/aeo/` },
      ],
    },
  ],
};
---
<BaseLayout
  title="AEO: Answer Engine Optimization | Masterful"
  description="Answer engine optimization for ChatGPT, Perplexity, Claude, and Gemini. We build pages that get cited by name."
  path="/services/aeo/"
  navActive="services"
>
  <script type="application/ld+json" slot="schema" set:html={JSON.stringify(graph)} />
  <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Services', href: '/services/' }, { name: 'AEO' }]} />

  <main>
  <section class="service-hero wrap">
    <div class="kicker" style="margin-bottom:20px">Service No. II · Answer Engine Optimization</div>
    <div class="sh-meta">
      <span class="sh-meta-item">Minimum 3 months</span>
      <span class="sh-meta-item">Flat retainer</span>
    </div>
    <h1 class="sh-headline">AEO:<br>the new <em>playbook.</em></h1>
    <p class="lead-body" style="max-width:640px;margin-bottom:32px">
      Answer engine optimization (AEO) is the practice of structuring web content so that AI tools (ChatGPT, Perplexity, Claude, and Gemini) retrieve and cite it when answering user queries. Where SEO targets Google's ranking algorithm, AEO targets the retrieval and citation logic of large language models. A page optimized for AEO answers a specific question with a clear, liftable thesis, structured headers that match query language, and schema markup that signals what the content covers.
    </p>
    <p class="sh-tagline">ChatGPT, Perplexity, and Gemini answer millions of questions a day. Most brands do not appear in a single one.</p>
    <a href="/audit/" class="btn btn-orange">Run a free audit</a>
  </section>

  <section class="pillars wrap">
    <div class="kicker" style="margin-bottom:32px">What We Build <span class="kicker-num">/ XII</span></div>
    <div class="pillar-grid">
      <div class="pillar">
        <h3>Finding your buyers' questions</h3>
        <p>We find the exact questions your buyers type into ChatGPT and Perplexity (and four more AI tools), then build content that answers them. Most brands have no idea what these questions are. We map them before we build anything.</p>
      </div>
      <div class="pillar">
        <h3>Source-engineered content</h3>
        <p>Pages built to match how models retrieve and cite information. The structure, depth, and source signals that make a page citable are different from what makes a page rank on Google. We build for both.</p>
      </div>
      <div class="pillar">
        <h3>Structured labels</h3>
        <p>We add labels to your site that help AI tools understand what you offer, who you serve, and what questions you answer. Deployed in the first two weeks.</p>
      </div>
      <div class="pillar">
        <h3>Weekly tracking across 6 AI tools</h3>
        <p>Your citation count tracked across the 6 major AI tools every week. A moving baseline that shows what the work is doing.</p>
      </div>
    </div>
  </section>

  <section class="wrap" style="padding:48px 0;border-bottom:1px solid var(--rule)">
    <div class="kicker" style="margin-bottom:20px">A Note on Timeline</div>
    <p style="font-size:15px;line-height:1.72;color:var(--ink);max-width:660px">AEO results show up in 30 to 90 days on Perplexity. ChatGPT and Gemini take longer because their indexes update on different schedules. We track all 6 major AI tools so the picture is accurate, not selectively optimistic.</p>
  </section>

  <section class="wrap section-sm" style="display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--rule)">
    <a href="/services/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute)">← All services</a>
    <div class="silo-links">
      <a href="/services/seo/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute)">← SXO & Core SEO</a>
      <a href="/services/geo/" class="t-mono link-ul" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--orange)">GEO →</a>
    </div>
  </section>

  <section class="on-dark" style="padding:80px 32px;text-align:center">
    <div class="wrap" style="max-width:600px">
      <p style="font-size:15px;line-height:1.65;color:rgba(244,240,232,0.65);max-width:440px;margin:0 auto 24px">The free audit shows your current citation count across all six models before we discuss anything.</p>
      <a href="/audit/" class="btn btn-orange">Run a free audit</a>
    </div>
  </section>
  </main>
</BaseLayout>
