---
import BaseLayout from '../../layouts/BaseLayout.astro';
const SITE = 'https://masterful-app.com';
const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Masterful Journal',
  description: 'Field notes on getting cited by AI tools. SEO, AEO, and GEO methods published in public.',
  url: `${SITE}/journal/`,
  publisher: { '@type': 'ProfessionalService', '@id': `${SITE}/#organization`, name: 'Masterful', url: SITE },
  author: { '@type': 'Person', '@id': `${SITE}/#jordan-shammah`, name: 'Jordan Shammah' },
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Journal', item: `${SITE}/journal/` },
  ],
};
---
<BaseLayout
  title="SEO, AEO & GEO Journal | Masterful"
  description="Field notes on getting cited. We write down what worked, what didn't, and what we'd charge for elsewhere. Not weekly. Not on a cadence."
  path="/journal/"
  navActive="journal"
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(blogLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  </Fragment>

  <main>
  <section class="wrap">
    <div class="journal-hero">
      <div>
        <div class="kicker" style="margin-bottom:24px">Journal · Field Notes on Getting Cited</div>
        <h1 style="font-family:var(--serif);font-size:clamp(44px,5.5vw,72px);line-height:1.0;letter-spacing:-0.02em;margin-bottom:16px">Field notes. Published.</h1>
        <p style="font-size:15px;line-height:1.65;color:var(--mute);max-width:440px">We write down what worked, including things we'd usually bill for. Posted when the result is worth the read.</p>
      </div>
      <div class="journal-stats">
        <div class="stat-block">
          <div class="stat-n">6</div>
          <div class="stat-l">Entries</div>
        </div>
        <div class="stat-block" style="grid-column:1/-1">
          <div class="stat-n" style="font-size:20px;font-family:var(--sans);font-weight:400">Updated June 2026</div>
          <div class="stat-l">Last entry</div>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule">

  <!-- Lead entry -->
  <section class="wrap">
    <div class="kicker" style="margin:40px 0 32px">Lead Entry <span class="kicker-num">/ XII</span></div>
    <div class="lead-entry" data-reveal>
      <div class="le-img">
        <div style="display:flex;gap:8px;margin-top:0">
          <span class="tag tag-filled">AEO</span>
          <span class="tag tag-filled">SEO</span>
        </div>
      </div>
      <div class="le-content">
        <div class="ec-date">May 25, 2026 · 7 min read</div>
        <h2 style="font-family:var(--serif);font-size:clamp(24px,3vw,36px);line-height:1.1;letter-spacing:-0.01em;margin-bottom:14px">Google Replaced the Search Bar. Your Brand Either Gets Cited or Gets Skipped.</h2>
        <p style="font-size:15px;line-height:1.65;color:var(--mute);margin-bottom:24px">On 19 May 2026, Google replaced the traditional search bar with a Gemini-powered interface that holds context, runs background agents, and cites brands by name. The ten blue links are gone. What this means for your visibility.</p>
        <div style="display:flex;align-items:center;gap:16px;margin-bottom:28px">
          <span class="t-mono" style="font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute)">By Jordan Shammah</span>
        </div>
        <a href="/journal/google-replaced-the-search-bar/" class="btn btn-orange">Read the entry →</a>
      </div>
    </div>
  </section>

  <hr class="rule">

  <!-- Recent entries -->
  <section class="wrap">
    <div class="kicker" style="margin:40px 0 32px">Recent Entries</div>
    <div class="entries-grid">

      <div class="entry-card" data-reveal>
        <div class="ec-tag">AEO</div>
        <div class="ec-date">Jun 06, 2026 · 4 min</div>
        <h3 class="ec-headline">Why your hotel doesn't show up when guests ask AI for a recommendation.</h3>
        <p class="ec-body">Travellers now ask ChatGPT and Perplexity where to stay. Why your property isn't in the answer, the three reasons it's invisible, and what changes it.</p>
        <a href="/journal/hotel-not-showing-up-in-ai-recommendations/" class="t-mono link-ul ec-read" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase">Read →</a>
      </div>

      <div class="entry-card" data-reveal>
        <div class="ec-tag">AEO</div>
        <div class="ec-date">May 14, 2026 · 8 min</div>
        <h3 class="ec-headline">How we got Perplexity to cite us in a category we don't rank for on Google.</h3>
        <p class="ec-body">A play-by-play of an AEO sprint that moved a brand from zero citations to first-page mentions in 38 days. The prompt-map spreadsheet and the schema we shipped.</p>
        <a href="/journal/perplexity-citation/" class="t-mono link-ul ec-read" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase">Read →</a>
      </div>

      <div class="entry-card" data-reveal>
        <div class="ec-tag">AEO</div>
        <div class="ec-date">May 08, 2026 · 7 min</div>
        <h3 class="ec-headline">How LLMs decide what to cite, and what your brand can do about it.</h3>
        <p class="ec-body">The retrieval mechanics behind ChatGPT, Perplexity, and Claude. Why some brands get cited and most don't. What to build to change that.</p>
        <a href="/journal/how-llms-decide-what-to-cite/" class="t-mono link-ul ec-read" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase">Read →</a>
      </div>

      <div class="entry-card" data-reveal>
        <div class="ec-tag">GEO</div>
        <div class="ec-date">Apr 28, 2026 · 6 min</div>
        <h3 class="ec-headline">GEO in plain language: what generative engine optimization involves.</h3>
        <p class="ec-body">Wikipedia, Reddit, and what AI tools read during training: what GEO is, why it's slower than SEO, and why that's the point.</p>
        <a href="/journal/what-geo-actually-is/" class="t-mono link-ul ec-read" style="font-size:11px;letter-spacing:0.06em;text-transform:uppercase">Read →</a>
      </div>

    </div>
  </section>

  <section class="on-dark" style="padding:80px 32px;text-align:center">
    <div class="wrap" style="max-width:600px">
      <h2 style="font-family:var(--serif);font-size:clamp(36px,5vw,60px);line-height:1.0;letter-spacing:-0.02em;margin-bottom:28px">Want us to audit your <em style="font-style:italic">visibility</em>?</h2>
      <a href="/audit/" class="btn btn-orange">Start for free →</a>
    </div>
  </section>
  </main>
</BaseLayout>
