---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
const SITE = 'https://masterful-app.com';
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'The Self-Test', item: `${SITE}/proof/` },
  ],
};
const queries = [
  {
    id: 'Q1',
    query: 'how to get my business cited by ChatGPT',
    perplexity: 'Masterful absent, all runs',
    aio: 'Absent',
    cited: 'procloser, digitalbroccoli, contently; Reddit r/b2bmarketing and a YouTube video inside the AIO panel',
  },
  {
    id: 'Q2',
    query: 'AI visibility audit',
    perplexity: 'Masterful absent, all runs',
    aio: 'Absent',
    cited: 'luxurypresence, ahrefs, groundingpage; organic page 1 held by valantic, Ahrefs, GoVISIBLE, Greenpark',
  },
  {
    id: 'Q3',
    query: 'how do coaches get recommended by ChatGPT',
    perplexity: 'Masterful absent, all runs',
    aio: 'Absent',
    cited: 'citedaisearch, niftysite, rcdigital; LinkedIn articles and techknowtools inside the AIO panel',
  },
  {
    id: 'Q4',
    query: 'perplexity citation gap analysis',
    perplexity: 'Masterful absent, all runs',
    aio: 'Absent',
    cited: 'authoritytech (3 of 3 runs), whitehat-seo, seodatapulse',
  },
  {
    id: 'Q5',
    query: 'does perplexity cite my website',
    perplexity: 'Masterful absent, all runs',
    aio: 'Absent',
    cited: 'clickrank, rebuilt.studio, digitaltechmainia, jottler (each 3 of 3 runs)',
  },
];
const checkpoints = ['Day 5', 'Day 10', 'Day 15', 'Day 20'];
---
<BaseLayout
  title="The Self-Test: Client Zero Receipts | Masterful"
  description="We run our citation method on our own site, in public. Day 0 baseline: zero citations in 15 logged runs across 5 queries. Checkpoints at days 5, 10, 15, and 20, published win or lose."
  path="/proof/"
  navActive=""
>
  <script type="application/ld+json" slot="schema" set:html={JSON.stringify(breadcrumb)} />
  <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'The Self-Test' }]} />

  <main>
  <section class="wrap" style="padding:64px 0 40px;border-bottom:1px solid var(--rule)">
    <div class="kicker" style="margin-bottom:24px">The Self-Test · Lab Notebook</div>
    <h1 style="font-family:var(--serif);font-size:clamp(40px,5vw,64px);line-height:1.0;letter-spacing:-0.02em;margin-bottom:20px">The self-test: client zero receipts</h1>
    <p style="font-size:16px;line-height:1.7;color:var(--ink);max-width:660px;margin-bottom:12px">We run our citation method on our own site and publish the results here. Day 0 is 10 June 2026. Checkpoints land at days 5, 10, 15, and 20, win or lose. At the start of the test, masterful-app.com had an Ahrefs DR of 0.</p>
    <p style="font-size:15px;line-height:1.7;color:var(--mute);max-width:660px">The method we are testing is the one in <a href="/journal/get-cited-by-chatgpt/" class="link-ul" style="color:var(--orange)">the ChatGPT citation guide</a>. The audit that maps the same gaps for a client is <a href="/audit/" class="link-ul" style="color:var(--orange)">here</a>.</p>
  </section>

  <!-- METHOD -->
  <section class="wrap" style="padding:40px 0;border-bottom:1px solid var(--rule)">
    <div class="kicker" style="margin-bottom:20px">Method</div>
    <p style="font-size:15px;line-height:1.7;color:var(--ink);max-width:660px;margin-bottom:10px">Logged-out runs, 3 per query. A citation counts when it appears in 2 of 3 runs. The query list below is locked for the duration of the test: no swapping queries that fail to move.</p>
    <p style="font-size:14px;line-height:1.7;color:var(--mute);max-width:660px">Known flaw in the day 0 data: some runs carried partial session personalization. Later checkpoints cure this with private-window runs.</p>
  </section>

  <!-- DAY 0 TABLE -->
  <section class="wrap" style="padding:48px 0;border-bottom:1px solid var(--rule)">
    <div class="kicker" style="margin-bottom:24px">Day 0 · 10 June 2026 · Baseline</div>
    <p style="font-size:15px;line-height:1.7;color:var(--ink);max-width:660px;margin-bottom:24px">Result: Masterful appeared in 0 of 15 logged runs across the 5 queries. The table prints who got cited instead, by name.</p>
    <div style="overflow-x:auto">
      <table style="width:100%;border-collapse:collapse;font-size:13px;line-height:1.5">
        <thead>
          <tr style="border-bottom:2px solid var(--ink);text-align:left">
            <th style="padding:10px 12px 10px 0;font-family:var(--mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase;white-space:nowrap">#</th>
            <th style="padding:10px 12px;font-family:var(--mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase">Query</th>
            <th style="padding:10px 12px;font-family:var(--mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase">Perplexity, day 0</th>
            <th style="padding:10px 12px;font-family:var(--mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase">AI Overview, day 0</th>
            <th style="padding:10px 0 10px 12px;font-family:var(--mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase">Who got cited instead</th>
          </tr>
        </thead>
        <tbody>
          {queries.map((q) => (
            <tr style="border-bottom:1px solid var(--rule)">
              <td style="padding:12px 12px 12px 0;vertical-align:top;font-family:var(--mono);font-size:11px">{q.id}</td>
              <td style="padding:12px;vertical-align:top;font-style:italic">"{q.query}"</td>
              <td style="padding:12px;vertical-align:top;color:var(--mute)">{q.perplexity}</td>
              <td style="padding:12px;vertical-align:top;color:var(--mute)">{q.aio}</td>
              <td style="padding:12px 0 12px 12px;vertical-align:top">{q.cited}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Screenshot slots: images to be supplied; placeholders only, nothing fabricated -->
    <div class="grid-3" style="margin-top:32px;gap:16px">
      <figure style="margin:0">
        <div class="imgph" style="aspect-ratio:4/3">Day 0 · Q1 screenshot · pending upload</div>
        <figcaption class="t-mono" style="font-size:9px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute);margin-top:8px">Q1 run log, competitor names visible</figcaption>
      </figure>
      <figure style="margin:0">
        <div class="imgph" style="aspect-ratio:4/3">Day 0 · Q2 screenshot · pending upload</div>
        <figcaption class="t-mono" style="font-size:9px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute);margin-top:8px">Q2 run log, competitor names visible</figcaption>
      </figure>
      <figure style="margin:0">
        <div class="imgph" style="aspect-ratio:4/3">Day 0 · Q3-Q5 screenshots · pending upload</div>
        <figcaption class="t-mono" style="font-size:9px;letter-spacing:0.06em;text-transform:uppercase;color:var(--mute);margin-top:8px">Q3 to Q5 run logs, competitor names visible</figcaption>
      </figure>
    </div>
  </section>

  <!-- CHECKPOINTS -->
  {checkpoints.map((day) => (
    <section class="wrap" style="padding:40px 0;border-bottom:1px solid var(--rule)">
      <div class="kicker" style="margin-bottom:16px">{day} · Checkpoint</div>
      <p style="font-size:15px;line-height:1.7;color:var(--mute);max-width:660px"><span class="tag" style="margin-right:10px">Pending</span>Results post here after the {day.toLowerCase()} runs. Same 5 queries, same method, private-window runs.</p>
    </section>
  ))}

  <!-- FOOT -->
  <section class="wrap" style="padding:40px 0 64px">
    <p style="font-size:14px;line-height:1.7;color:var(--mute);max-width:660px">This page exists so nobody has to take our word for it, including our own clients. If the test fails, the failed checkpoints stay published. The method under test is documented in <a href="/journal/get-cited-by-chatgpt/" class="link-ul" style="color:var(--orange)">the citation guide</a>, and the client version of this diagnosis is <a href="/audit/" class="link-ul" style="color:var(--orange)">the audit</a>.</p>
  </section>
  </main>
</BaseLayout>
