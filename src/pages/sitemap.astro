---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const SITE = 'https://masterful-app.com';
const journal = await getCollection('journal');
const work = await getCollection('work');

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Sitemap', item: `${SITE}/sitemap/` },
  ],
};
---
<BaseLayout
  title="Sitemap | Masterful"
  description="Every page on masterful-app.com in one place: services, sectors, case studies, and the journal."
  path="/sitemap/"
  navActive=""
>
  <script type="application/ld+json" slot="schema" set:html={JSON.stringify(breadcrumb)} />
  <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Sitemap' }]} />

  <main>
  <section class="section wrap">
    <div class="kicker" style="margin-bottom:24px">The Index · Every Page</div>
    <h1 style="font-family:var(--serif);font-size:clamp(44px,5.5vw,72px);line-height:1.0;letter-spacing:-0.02em;margin-bottom:16px">Sitemap</h1>
    <p style="font-size:16px;line-height:1.65;color:var(--mute);max-width:560px;margin-bottom:8px">Everything on masterful-app.com, in one place. Looking for the machine-readable version? The <a href="/sitemap-index.xml" class="link-ul" style="color:var(--orange)">XML sitemap</a> is for search engines.</p>

    <div class="sitemap-grid">
      <div class="sitemap-col">
        <h2 class="sitemap-h">Main</h2>
        <ul class="sitemap-list">
          <li><a href="/">Home</a></li>
          <li><a href="/audit/">Free audit</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/process/">Process</a></li>
        </ul>
      </div>

      <div class="sitemap-col">
        <h2 class="sitemap-h">Services</h2>
        <ul class="sitemap-list">
          <li><a href="/services/">Search visibility services</a></li>
          <li>
            <a href="/services/seo/">SXO & Core SEO</a>
            <ul class="sitemap-sub">
              <li><a href="/services/seo/technical-seo/">Technical SEO</a></li>
              <li><a href="/services/seo/seo-audit/">SEO audit</a></li>
              <li><a href="/services/seo/local-seo-nairobi/">Local SEO Nairobi</a></li>
            </ul>
          </li>
          <li><a href="/services/aeo/">AEO</a></li>
          <li><a href="/services/geo/">GEO</a></li>
          <li><a href="/services/web-design/">Web design</a></li>
        </ul>
      </div>

      <div class="sitemap-col">
        <h2 class="sitemap-h">Sectors</h2>
        <ul class="sitemap-list">
          <li><a href="/sectors/">Sectors</a></li>
          <li><a href="/sectors/law-firms/">Law firms</a></li>
          <li><a href="/sectors/saas/">SaaS</a></li>
          <li><a href="/sectors/hospitality/">Hospitality</a></li>
          <li><a href="/sectors/nairobi-businesses/">Nairobi businesses</a></li>
        </ul>
      </div>

      <div class="sitemap-col">
        <h2 class="sitemap-h">Work</h2>
        <ul class="sitemap-list">
          <li><a href="/work/">Work</a></li>
          {work.map((w) => (
            <li><a href={`/work/${w.id}/`}>{w.data.title}</a></li>
          ))}
        </ul>
      </div>

      <div class="sitemap-col">
        <h2 class="sitemap-h">Journal</h2>
        <ul class="sitemap-list">
          <li><a href="/journal/">Journal</a></li>
          {journal.map((p) => (
            <li><a href={`/journal/${p.id}/`}>{p.data.breadcrumbName}</a></li>
          ))}
        </ul>
      </div>

      <div class="sitemap-col">
        <h2 class="sitemap-h">Machine-readable</h2>
        <ul class="sitemap-list">
          <li><a href="/sitemap-index.xml">XML sitemap</a></li>
          <li><a href="/llms.txt">llms.txt</a></li>
          <li><a href="/robots.txt">robots.txt</a></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="on-dark" style="padding:72px 32px;text-align:center">
    <div class="wrap" style="max-width:600px">
      <h2 style="font-family:var(--serif);font-size:clamp(32px,4.5vw,52px);line-height:1.05;letter-spacing:-0.02em;margin-bottom:16px">Found what you needed?</h2>
      <p style="font-size:15px;line-height:1.65;color:rgba(244,240,232,0.65);max-width:420px;margin:0 auto 28px">The fastest way to see where you stand is the free audit. Six questions, a human reply within 48 hours.</p>
      <a href="/audit/" class="btn btn-orange">Run a free audit →</a>
    </div>
  </section>
  </main>
</BaseLayout>
