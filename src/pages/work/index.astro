---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const SITE = 'https://masterful-app.com';
const studies = await getCollection('work');
const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Work | Masterful',
  description:
    'The work format from Masterful, a search visibility studio: an 18-page AI visibility diagnosis run before any client pays.',
  url: `${SITE}/work/`,
  publisher: { '@type': 'ProfessionalService', '@id': `${SITE}/#organization`, name: 'Masterful' },
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Work', item: `${SITE}/work/` },
  ],
};
---
<BaseLayout
  title="Work | Masterful"
  description="The Masterful audit is the work you can see before you hire us: an 18-page AI visibility diagnosis of your brand, run before you pay anything."
  path="/work/"
  navActive="work"
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(collectionLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  </Fragment>

  <main>
  <section class="wrap" style="padding:64px 0 48px;border-bottom:1px solid var(--rule)">
    <div class="kicker" style="margin-bottom:32px">Work · Selected Engagements</div>
    <h1 style="font-family:var(--serif);font-size:clamp(44px,5.5vw,72px);line-height:1.0;letter-spacing:-0.02em;margin-bottom:20px">Every result on this page carries real numbers and a named methodology.</h1>
    <p style="font-size:16px;line-height:1.65;color:var(--mute);max-width:560px;margin-bottom:16px">The audit format is the proof of work. See how we diagnose a brand's AI visibility in 18 pages before a client pays anything.</p>
    <p style="font-size:16px;line-height:1.65;color:var(--mute);max-width:560px;margin-bottom:32px">The audit is the work you can see before you hire us. Run it and judge the diagnosis on its merits.</p>
    {/* TODO(owner): Publish a real case study here once a client engagement
        produces verified, attributable numbers. The prior /work/northpath page
        was removed in the 2026-05-29 SEO audit because its metrics (Northpath
        Labs, +418%, $840K ARR, 38 prompts) were unverifiable and contradicted
        this page's own "first published case study is coming / verified numbers
        only" copy. Write the replacement from a real engagement with the
        client's permission to publish, then add it to the work collection
        (src/content/work/<client-slug>.md). */}
    <div style="display:flex;gap:12px;flex-wrap:wrap">
      <a href="/audit/" class="btn btn-orange">See the audit format →</a>
      <a href="/journal/" class="btn btn-ghost">Read the journal →</a>
    </div>
  </section>

  {studies.length > 0 && (
    <section class="wrap" style="padding:48px 0;border-bottom:1px solid var(--rule)">
      <div class="kicker" style="margin-bottom:32px">Case Studies</div>
      <ul class="related-list">
        {studies.map((s) => (
          <li><a href={`/work/${s.id}/`}>{s.data.title} →</a></li>
        ))}
      </ul>
    </section>
  )}

  <section class="on-dark" style="padding:80px 32px;text-align:center">
    <div class="wrap" style="max-width:600px">
      <h2 style="font-family:var(--serif);font-size:clamp(36px,5vw,60px);line-height:1.0;letter-spacing:-0.02em;margin-bottom:16px">Want your name<br><em style="font-style:italic">on this page?</em></h2>
      <p style="font-size:15px;line-height:1.65;color:rgba(244,240,232,0.65);max-width:400px;margin:0 auto 28px">The audit is free. Run it and you'll know within 48 hours whether it's worth moving forward.</p>
      <a href="/audit/" class="btn btn-orange">Run a free audit →</a>
    </div>
  </section>
  </main>
</BaseLayout>
