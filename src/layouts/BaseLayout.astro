---
import Nav from '../components/Nav.astro';
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';

const SITE = 'https://masterful-app.com';

interface Props {
  title: string;
  description: string;
  path: string; // canonical path, trailing-slash form e.g. "/services/seo/"
  ogType?: string;
  navActive?: string;
  navCta?: 'audit' | 'home';
  showMasthead?: boolean;
  showFooter?: boolean;
  floatingCta?: boolean;
  bodyClass?: string;
}

const {
  title,
  description,
  path,
  ogType = 'website',
  navActive = '',
  navCta = 'audit',
  showMasthead = true,
  showFooter = true,
  floatingCta = true,
  bodyClass = '',
} = Astro.props;

const canonical = SITE + path;
const ogImage = `${SITE}/assets/og-image.png`;
---
<!doctype html>
<html lang="en">
<head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-HC09ZGS24H"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-HC09ZGS24H');
</script>
<meta charset="utf-8" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="color-scheme" content="light" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500;700&family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/main.css" />
<script src="https://analytics.ahrefs.com/analytics.js" data-key="HPnxBNECL6yALmHVmKBNGA" async></script>
<!-- Microsoft Clarity -->
<script is:inline type="text/javascript">
  (function(c,l,a,r,i,t,y){
      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
  })(window, document, "clarity", "script", "x50x3y00tb");
</script>
<script is:inline>function initApollo(){var n=Math.random().toString(36).substring(7),o=document.createElement("script");o.src="https://assets.apollo.io/micro/website-tracker/tracker.iife.js?nocache="+n,o.async=!0,o.defer=!0,o.onload=function(){window.trackingFunctions.onLoad({appId:"6a25384f1ec5c500205ede12"})},document.head.appendChild(o)}initApollo();</script>
<noscript><style>[data-reveal],[data-hero]{opacity:1!important;transform:none!important}</style></noscript>

<link rel="canonical" href={canonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={ogType} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="2400" />
<meta property="og:image:height" content="1260" />
<meta property="og:image:alt" content="Masterful, a search visibility studio" />
<meta property="og:site_name" content="Masterful" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<slot name="schema" />
</head>
<body class={bodyClass}>
<Nav active={navActive} cta={navCta} />
{showMasthead && <Masthead />}
<slot />
{showFooter && <Footer />}
{floatingCta && (
  <a href="/audit/" class="shortlist-cta glass" id="shortlist-cta" aria-label="Get on the shortlist — start the free audit">
    <span class="sc-dot"></span>Get on the shortlist →
  </a>
)}

<script is:inline>
  (function () {
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Orchestrated masthead / hero entry on load.
    requestAnimationFrame(function () { document.documentElement.classList.add('hero-ready'); });

    // Scroll reveals — fade-up, staggered, unobserve after first reveal.
    var revealEls = Array.prototype.slice.call(document.querySelectorAll('[data-reveal]'));
    if (reduce || !('IntersectionObserver' in window)) {
      revealEls.forEach(function (el) { el.classList.add('is-visible'); });
    } else {
      var io = new IntersectionObserver(function (entries, obs) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          var group = entry.target.parentElement
            ? Array.prototype.slice.call(entry.target.parentElement.querySelectorAll(':scope > [data-reveal]'))
            : [entry.target];
          var idx = group.indexOf(entry.target);
          entry.target.style.transitionDelay = (idx > -1 ? idx * 80 : 0) + 'ms';
          entry.target.classList.add('is-visible');
          obs.unobserve(entry.target);
        });
      }, { rootMargin: '0px 0px -10% 0px', threshold: 0.1 });
      revealEls.forEach(function (el) { io.observe(el); });
    }

    // Floating shortlist CTA — reveal after the first screen of scroll.
    var cta = document.getElementById('shortlist-cta');
    if (cta) {
      var onScroll = function () {
        if (window.scrollY > window.innerHeight * 0.6) cta.classList.add('is-visible');
        else cta.classList.remove('is-visible');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  })();
</script>
</body>
</html>
